# Copy this file to .env and fill values. Do NOT commit real credentials to git.
# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=luxury_crm
DB_USER=your_db_user
DB_PASS=your_db_password

# Deploy secret for scripts/auto_deploy.php
DEPLOY_SECRET=change_this_to_a_strong_random_value

# Enable seeding on login (only for development)
# Set to 1 to allow seedTestDataIfNeeded() to run after login
ALLOW_DB_SEEDING=0
